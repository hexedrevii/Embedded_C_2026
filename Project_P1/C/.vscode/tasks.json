{
    "tasks": [  // Array of build tasks
        {
            "type": "cppbuild",  // Indicates this is a C/C++ build task
            "label": "C/C++: gcc.exe build active file",  // Name of the task shown in VS Code
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",  // Path to the GCC compiler executable

            "args": [  // Array of arguments passed to the compiler
                "-fdiagnostics-color=always",  // Enables colored output in the terminal
                "-g",  // Generates debug information
                "${file}",  // The current file being edited
                "${workspaceFolder}\\sw\\FlowControl\\src\\Fcontrol.c",  // Path to additional source file
                "${workspaceFolder}\\sw\\FlowControl\\src\\MessagesGen.c",
                "-I${workspaceFolder}\\sw\\FlowControl\\inc",  // Adds include directory for header files
                "-I${workspaceFolder}\\sw\\DataTypes\\inc",
                "-o",  // Output flag
                "${fileDirname}\\${fileBasenameNoExtension}.exe"  // Output executable path and name
            ],

            "options": {
                "cwd": "${fileDirname}"  // Sets the working directory to the directory of the current file
            },

            "problemMatcher": [
                "$gcc"  // Uses GCC problem matcher to parse compiler output for errors
            ],

            "group": {
                "kind": "build",  // Identifies this as a build task
                "isDefault": true  // Makes this the default build task (triggered by Ctrl+Shift+B)
            },

            "detail": "Task generated by Debugger."  // Description shown in VS Code UI
        }
    ],
    "version": "2.0.0"  // Version of the tasks.json schema
}